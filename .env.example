# Copy to .env to override defaults. docker-compose already sets these for the
# container; this file is mainly for running the API locally without Docker.
DATABASE_URL=postgresql+asyncpg://hyogen:hyogen@localhost:5432/hyogen
KANJIAPI_BASE=https://kanjiapi.dev/v1
HTTP_TIMEOUT=15
CORS_ORIGINS=http://localhost,https://localhost,http://localhost:5173
